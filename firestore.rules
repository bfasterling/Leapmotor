rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Test Collection: For startup connection diagnostics
    match /test/{docId} {
      allow read, write: if true;
    }

    // Distributors Collection: Fully readable and writable by anyone
    match /distributors/{distId} {
      allow read, write: if true;
    }

    // Advisors Collection: Fully readable and writable to manage sales credentials and active distributors
    match /advisors/{advisorId} {
      allow read, write: if true;
    }

    // Leads Collection: Publicly writable on creation and fully manageable/readable by advisors and coordinates
    match /leads/{leadId} {
      allow read, write: if true;
    }
  }
}
