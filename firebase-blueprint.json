{
  "entities": {
    "Lead": {
      "title": "Lead",
      "description": "Un registro de prospecto interesado en Leapmotor Mexico para el evento",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Nombre del prospecto"
        },
        "lastName": {
          "type": "string",
          "description": "Apellido del prospecto"
        },
        "email": {
          "type": "string",
          "description": "Correo electrónico del prospecto"
        },
        "phone": {
          "type": "string",
          "description": "Número de teléfono/WhatsApp del prospecto"
        },
        "modelOfInterest": {
          "type": "string",
          "description": "Modelo de auto seleccionado de interes"
        },
        "city": {
          "type": "string",
          "description": "Ciudad de residencia en Mexico"
        },
        "postalCode": {
          "type": "string",
          "description": "Código postal del prospecto (opcional)"
        },
        "state": {
          "type": "string",
          "description": "Estado de la república mexicana"
        },
        "distributor": {
          "type": "string",
          "description": "Distribuidor seleccionado"
        },
        "status": {
          "type": "string",
          "description": "Estado de atencion",
          "enum": ["waiting", "attending", "attended", "lost"]
        },
        "notes": {
          "type": "string",
          "description": "Notas del asesor de ventas posterior a la atencion"
        },
        "advisorId": {
          "type": "string",
          "description": "ID del asesor de ventas que atiende"
        },
        "advisorName": {
          "type": "string",
          "description": "Nombre del asesor de ventas"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Fecha y hora de registro"
        },
        "attendedAt": {
          "type": "string",
          "format": "date-time",
          "description": "Fecha y hora en que se inicio la atencion"
        },
        "completedAt": {
          "type": "string",
          "format": "date-time",
          "description": "Fecha y hora de finalizacion del lead"
        },
        "contactMethod": {
          "type": "string",
          "description": "Metodo de contacto preferido"
        },
        "requestType": {
          "type": "string",
          "description": "Tipo de solicitud (cotizacion, prueba, asesor)",
          "enum": ["cotizacion", "prueba", "asesor"]
        },
        "landing": {
          "type": "string",
          "description": "Landing page de orígen: leapmotor, jeep, o multimarca"
        },
        "selectedBrand": {
          "type": "string",
          "description": "Marca seleccionada por el prospecto"
        },
        "testDriveDate": {
          "type": "string",
          "description": "Fecha seleccionada para la prueba de manejo (opcional para cotización/contacto)"
        }
      },
      "required": ["name", "lastName", "email", "phone", "modelOfInterest", "state", "distributor", "status", "createdAt"]
    },
    "Advisor": {
      "title": "Advisor",
      "description": "Un registro de asesor de ventas que atiende prospectos y gestiona accesos",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Nombre completo del asesor"
        },
        "email": {
          "type": "string",
          "description": "Correo electrónico del asesor"
        },
        "password": {
          "type": "string",
          "description": "Contraseña elegible para login en portal de asesor"
        },
        "active": {
          "type": "boolean",
          "description": "Define si el asesor está activo para poder recibir auto-asignaciones"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Fecha y hora de creación"
        }
      },
      "required": ["name", "email", "password", "active"]
    },
    "Distributor": {
      "title": "Distributor",
      "description": "Un registro de distribuidor / dealer oficial de las marcas",
      "type": "object",
      "properties": {
        "marca": {
          "type": "string",
          "description": "Marca del distribuidor"
        },
        "claveCorporativo": {
          "type": "string",
          "description": "Clave única corporativa"
        },
        "disId": {
          "type": "string",
          "description": "ID único de distribuidor"
        },
        "estado": {
          "type": "string",
          "description": "Estado de la república mexicana"
        },
        "name": {
          "type": "string",
          "description": "Nombre comercial del distribuidor"
        },
        "url": {
          "type": "string",
          "description": "URL de la ficha o sitio del distribuidor (opcional)"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Fecha y hora de carga"
        }
      },
      "required": ["marca", "claveCorporativo", "disId", "estado", "name"]
    }
  },
  "firestore": {
    "leads": {
      "schema": "Lead",
      "description": "Coleccion global de prospectos registrados en el evento de Leapmotor"
    },
    "advisors": {
      "schema": "Advisor",
      "description": "Coleccion de asesores comerciales registrados habilitados para login y atencion de leads"
    },
    "distributors": {
      "schema": "Distributor",
      "description": "Coleccion de distribuidores de las marcas oficiales para asignar leads"
    }
  }
}
